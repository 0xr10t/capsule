# Service endpoints
VITE_MARKETPLACE_API_URL=http://localhost:4000
VITE_DISCLOSURE_HOST_URL=http://localhost:4001
MARKETPLACE_API_URL=http://localhost:4000
MARKETPLACE_PORT=4000
DISCLOSURE_HOST_PORT=4001

# demo uses local memory and no on-chain transactions.
# testnet requires permanent Walrus storage plus a server-side Sui signer.
PROTOCOL_MODE=demo
STORAGE_DRIVER=memory
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=3
WALRUS_AUTH_TOKEN=

# Optional persistent marketplace repository.
DATABASE_URL=postgresql://capsule:capsule@localhost:5432/capsule
DATABASE_DRIVER=memory

# Server-only Sui signing. Never prefix the private key with VITE_ or commit .env.
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_PRIVATE_KEY=
SUI_PACKAGE_ID=

# Browser-readable public chain configuration for verification/display only.
VITE_SUI_NETWORK=testnet
VITE_CAPSULE_PACKAGE_ID=
VITE_PUBLISHER_SEALED_FRAGMENTS=false

# Seal-encrypted paid capsule delivery. These are public service identifiers/URLs.
# The default testnet committee below is listed in the official Seal documentation.
SEAL_CAPSULES=false
SEAL_KEY_SERVER_OBJECT_ID=0xb012378c9f3799fb5b1a7083da74a4069e3c3f1c93de0b27212a5799ce1e1e98
SEAL_AGGREGATOR_URL=https://seal-aggregator-testnet.mystenlabs.com
SEAL_THRESHOLD=1
VITE_SEAL_KEY_SERVER_OBJECT_ID=0xb012378c9f3799fb5b1a7083da74a4069e3c3f1c93de0b27212a5799ce1e1e98
VITE_SEAL_AGGREGATOR_URL=https://seal-aggregator-testnet.mystenlabs.com
VITE_SEAL_THRESHOLD=1
